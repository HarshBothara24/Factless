# FACTLESS Environment Configuration

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
FACTLESS_LOG_LEVEL=INFO
PYTHONPATH=/app

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Analysis Configuration
MAX_TEXT_LENGTH=10000
ENABLE_DETAILED_LOGGING=true

# Risk Thresholds
RISK_LOW_THRESHOLD=0.3
RISK_HIGH_THRESHOLD=0.7

# Module Weights
WEIGHT_CONTRADICTION=0.25
WEIGHT_LOGICAL_FLOW=0.20
WEIGHT_OVERCONFIDENCE=0.15
WEIGHT_CLAIM_DENSITY=0.15
WEIGHT_ENTITY_FABRICATION=0.25
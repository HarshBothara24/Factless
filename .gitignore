.user
*.user

# ============================================================================
# Keep These Files
# ============================================================================

# Keep example environment file
!.env.example

# Keep README files
!README.md
!*/README.md

# Keep example configurations
!*example*
!*EXAMPLE*

# Keep documentation
!docs/
!*.md

# Keep test files
!tests/
!test_*.py

# Keep requirements
!requirements.txt
!package.json

# Keep Docker files
!Dockerfile
!docker-compose.yml
!.dockerignore